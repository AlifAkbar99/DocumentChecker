# Salin file ini jadi ".env" lalu isi nilainya.

# Wajib: API key dari https://console.mistral.ai/
MISTRAL_API_KEY=

# Opsional: model Mistral yang dipakai (default: mistral-large-latest)
# Pilihan lain misalnya: mistral-small-latest
MISTRAL_MODEL=mistral-large-latest

# Opsional: secret key untuk Flask session. Ganti dengan string random di produksi.
FLASK_SECRET_KEY=
